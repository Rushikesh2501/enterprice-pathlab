{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://enterprice-pathlab.onrender.com/api/:match*"
    },
    {
      "source": "/((?!api|assets|logo.svg).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
